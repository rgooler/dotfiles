#!/bin/bash
# Install packages: baseline.all -> (gui) baseline.gui -> each enabled profile,
# dispatched by .pkgmgr. Then mise-managed runtimes. Runs on change of the
# package/profile/tool sets, AFTER dotfiles and AFTER the before-script.

{{ template "utils" }}

set -uo pipefail

# Re-run when any of these change:
# baseline: {{ .packages.baseline.all }}
# gui:      {{ .packages.baseline.gui }}
# enabled:  {{ .profiles }}
# defs:     {{ .packages.profiles }}
# tools:    {{ include "dot_tool-versions" | sha256sum }}

{{ if eq .pkgmgr "brew" }}
##############################################################################
# macOS: Homebrew bundle (baseline + gui + profiles via the brew template)
##############################################################################
if exist brew; then
    eval "$(brew shellenv)"
    info "Installing brew packages..."
{{ template "brew" . }}
    if [ $? -eq 0 ]; then
        success "Successfully installed brew packages."
    else
        fail "Some or all brew packages failed to install."
    fi
else
    fail "Command 'brew' not found in PATH. Skipping brew packages."
fi

{{ else if eq .pkgmgr "dnf" }}
##############################################################################
# Fedora: dnf + flatpak
##############################################################################
DNF_PKGS="{{ range .packages.baseline.all.dnf }}{{ . }} {{ end }}{{ if .gui }}{{ range .packages.baseline.gui.dnf }}{{ . }} {{ end }}{{ end }}{{ range $p := .profiles }}{{ range (index $.packages.profiles $p).dnf }}{{ . }} {{ end }}{{ end }}"
info "Installing dnf packages: $DNF_PKGS"
if sudo dnf install -y $DNF_PKGS; then
    success "dnf packages installed."
else
    fail "Some dnf packages failed to install."
fi

{{ else if eq .pkgmgr "apt" }}
##############################################################################
# Debian/Ubuntu/Kali (UNTESTED)
##############################################################################
export DEBIAN_FRONTEND=noninteractive
APT_PKGS="{{ range .packages.baseline.all.apt }}{{ . }} {{ end }}{{ if .gui }}{{ range .packages.baseline.gui.apt }}{{ . }} {{ end }}{{ end }}{{ range $p := .profiles }}{{ range (index $.packages.profiles $p).apt }}{{ . }} {{ end }}{{ end }}"
sudo apt-get update -y
info "Installing apt packages: $APT_PKGS"
if sudo apt-get install -y $APT_PKGS; then
    success "apt packages installed."
else
    fail "Some apt packages failed to install."
fi
{{ end }}

##############################################################################
# flatpak apps (all Linux GUI machines)
##############################################################################
# Runs independently of the system package manager. SteamOS/immutable Decks have
# no usable pkgmgr (.pkgmgr == "") yet do ship flatpak, so this can't live inside
# the dnf/apt arms above. Scope follows machine class: desktops (dnf/apt) install
# system-wide as before; a Deck (empty pkgmgr, read-only root, no sudo) installs
# per-user.
{{ if and (eq .chezmoi.os "linux") .gui }}
FLATPAK_SCOPE="{{ if eq .pkgmgr "" }}--user{{ else }}--system{{ end }}"
FLATPAK_PKGS="{{ range .packages.baseline.gui.flatpak }}{{ . }} {{ end }}{{ range $p := .profiles }}{{ range (index $.packages.profiles $p).flatpak }}{{ . }} {{ end }}{{ end }}"
if [ -n "${FLATPAK_PKGS// /}" ]; then
    if ! exist flatpak; then
{{ if eq .pkgmgr "dnf" }}        sudo dnf install -y flatpak
{{ else if eq .pkgmgr "apt" }}        sudo apt-get install -y flatpak
{{ else }}        fail "flatpak not found and no usable package manager to install it; skipping flatpak apps."
{{ end }}    fi
    if exist flatpak; then
        flatpak remote-add $FLATPAK_SCOPE --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
        info "Installing flatpak apps ($FLATPAK_SCOPE): $FLATPAK_PKGS"
        # Install per-app so one failure can't abort the batch, and skip anything
        # already installed from any remote/scope. Entries may be "remote:appid"
        # to pin a remote (e.g. fedora:io.mpv.Mpv — the flathub build had issues);
        # a bare id defaults to flathub.
        fp_fail=0
        for spec in $FLATPAK_PKGS; do
            remote=flathub; app=$spec
            case "$spec" in *:*) remote=${spec%%:*}; app=${spec#*:};; esac
            if flatpak info "$app" >/dev/null 2>&1; then
                info "Skipping $app (already installed)"
                continue
            fi
            if ! flatpak install $FLATPAK_SCOPE -y "$remote" "$app"; then
                fail "flatpak: failed to install $app from $remote"
                fp_fail=1
            fi
        done
        if [ "$fp_fail" -eq 0 ]; then
            success "flatpak apps installed."
        else
            fail "Some flatpak apps failed to install."
        fi
    fi
fi
{{ end }}

##############################################################################
# atuin — shell history, personal-trust machines only (installed via mise)
##############################################################################
{{ if eq .trust "personal" }}
if exist mise; then
    info "Installing atuin via mise..."
    if mise use -g atuin@latest; then
        success "atuin installed via mise."
    else
        fail "atuin (mise) install failed."
    fi
fi
{{ end }}

##############################################################################
# mise runtimes (all OSes, from ~/.tool-versions)
##############################################################################
if ! exist mise; then
{{ if eq .pkgmgr "brew" }}
    if exist brew; then info "Installing mise via Homebrew..."; brew install mise; fi
{{ else }}
    info "Installing mise via mise.run installer..."
    curl -fsSL https://mise.run | sh
    export PATH="$HOME/.local/bin:$PATH"
{{ end }}
fi

if exist mise; then
    info "Installing tools with mise (from ~/.tool-versions)..."
    if mise install; then
        success "mise tools installed."
    else
        fail "mise install failed."
    fi
else
    fail "mise not found in PATH; skipping tool install."
fi
