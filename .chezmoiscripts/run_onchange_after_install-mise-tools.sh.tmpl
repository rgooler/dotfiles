#!/bin/bash

{{ template "utils" }}

# Re-run this script whenever the managed tool list changes:
# tool-versions hash: {{ include "dot_tool-versions" | sha256sum }}

# --- ensure mise is installed ---
if ! exist mise; then
{{ if eq .osid "darwin" }}
    if exist brew; then
        info "Installing mise via Homebrew..."
        brew install mise
    fi
{{ else if eq .osid "linux" }}
    info "Installing mise via mise.run installer..."
    curl -fsSL https://mise.run | sh
    export PATH="$HOME/.local/bin:$PATH"
{{ end }}
fi

# --- install the runtimes pinned in ~/.tool-versions ---
if exist mise; then
    info "Installing tools with mise (from ~/.tool-versions)..."
    if mise install; then
        success "mise tools installed."
    else
        fail "mise install failed."
    fi
else
    fail "mise not found in PATH; skipping tool install."
fi
