#!/bin/bash
# Enable the RetroDECK save-sync systemd user units + user lingering. Runs after
# packages and the unit/script files are applied, and re-runs whenever any of
# them change. Gated to the `emulation` profile (see .chezmoiignore for the
# matching file gate). Named to sort AFTER run_onchange_after_install-packages
# so rclone/inotify-tools/RetroDECK exist before we enable the units.
{{ if and (has "emulation" .profiles) (eq .chezmoi.os "linux") -}}
{{ template "utils" }}

set -uo pipefail

# ~/.local/bin holds the per-user rclone fallback (installed just below on
# immutable systems); keep it on PATH.
export PATH="$HOME/.local/bin:$PATH"

# Re-run when the script or any unit changes:
# script: {{ include "dot_local/bin/executable_retrodeck-sync.sh" | sha256sum }}
# svc:    {{ include "dot_config/systemd/user/retrodeck-sync.service" | sha256sum }}
# tsvc:   {{ include "dot_config/systemd/user/retrodeck-sync-timer.service" | sha256sum }}
# timer:  {{ include "dot_config/systemd/user/retrodeck-sync.timer" | sha256sum }}
# watch:  {{ include "dot_config/systemd/user/retrodeck-sync-watch.service" | sha256sum }}

# Dependencies. rclone + inotifywait normally come from the emulation profile's
# packages, but immutable SteamOS can't use the package manager — fall back to a
# per-user rclone in ~/.local/bin (the script + units already have it on PATH).
if ! command -v rclone >/dev/null 2>&1; then
    info "retrodeck-sync: rclone not found — installing a per-user copy (SteamOS/immutable fallback)..."
    if command -v unzip >/dev/null 2>&1; then
        mkdir -p "$HOME/.local/bin"; _t=$(mktemp -d)
        if curl -fsSL https://downloads.rclone.org/rclone-current-linux-amd64.zip -o "$_t/r.zip" \
           && unzip -j "$_t/r.zip" '*/rclone' -d "$HOME/.local/bin" >/dev/null; then
            chmod +x "$HOME/.local/bin/rclone"; success "rclone installed to ~/.local/bin."
        else
            fail "rclone download failed — sync won't run until rclone is on PATH."
        fi
        rm -rf "$_t"
    else
        fail "rclone missing and 'unzip' unavailable — install rclone manually."
    fi
fi
# inotifywait powers the real-time watcher. On stock SteamOS it's absent and the
# root is immutable, so install a per-user copy by extracting the Arch package
# into ~/.local (bin + lib; the script exports LD_LIBRARY_PATH so it resolves).
# Any failure here is non-fatal — the ~15m timer still syncs.
if ! command -v inotifywait >/dev/null 2>&1; then
    info "retrodeck-sync: inotifywait missing — installing a per-user inotify-tools from the Arch package..."
    if command -v tar >/dev/null 2>&1 && tar --help 2>/dev/null | grep -q -- --zstd; then
        _it=$(mktemp -d)
        if curl -fsSL "https://archlinux.org/packages/extra/x86_64/inotify-tools/download/" -o "$_it/it.pkg.tar.zst" \
           && tar -C "$_it" --zstd -xf "$_it/it.pkg.tar.zst" usr/bin/inotifywait usr/lib >/dev/null 2>&1; then
            mkdir -p "$HOME/.local/bin" "$HOME/.local/lib"
            install -m755 "$_it/usr/bin/inotifywait" "$HOME/.local/bin/inotifywait"
            cp -Pf "$_it"/usr/lib/libinotifytools.so* "$HOME/.local/lib/" 2>/dev/null
            hash -r 2>/dev/null || true
            command -v inotifywait >/dev/null 2>&1 \
                && success "inotify-tools installed to ~/.local (bin+lib)." \
                || fail "inotifywait installed but not detected — watcher stays off (timer still syncs)."
        else
            fail "inotify-tools download/extract failed — watcher off (timer still syncs)."
        fi
        rm -rf "$_it"
    else
        fail "tar with --zstd unavailable — cannot unpack inotify-tools; watcher off (timer still syncs)."
    fi
fi

info "retrodeck-sync: reloading systemd user units..."
systemctl --user daemon-reload

info "retrodeck-sync: enabling safety-net timer..."
if systemctl --user enable --now retrodeck-sync.timer; then
    success "retrodeck-sync.timer enabled."
else
    fail "Could not enable retrodeck-sync.timer (is the user systemd bus up?)."
fi

# The recursive watcher needs inotifywait; without it its --watch mode exits 1
# and (Restart=on-failure) crash-loops. Enable it only when inotifywait exists
# (e.g. not on stock SteamOS); otherwise make sure it's off and lean on the timer.
if command -v inotifywait >/dev/null 2>&1; then
    if systemctl --user enable --now retrodeck-sync-watch.service; then
        success "retrodeck-sync-watch enabled (real-time sync)."
    else
        fail "Could not enable retrodeck-sync-watch."
    fi
else
    systemctl --user disable --now retrodeck-sync-watch.service >/dev/null 2>&1 || true
    info "retrodeck-sync: inotifywait missing — watcher left disabled; the ~15m timer handles sync."
fi

# Lingering lets the timer/watcher run while logged out and survive reboot.
# Needs sudo once; never fail the whole apply if we can't get it here.
if [ "$(loginctl show-user "$USER" -p Linger --value 2>/dev/null)" = "yes" ]; then
    success "retrodeck-sync: user lingering already enabled."
elif sudo -n loginctl enable-linger "$USER" 2>/dev/null; then
    success "retrodeck-sync: user lingering enabled."
else
    info "NOTE: run 'sudo loginctl enable-linger $USER' so syncs run while logged out."
fi

info "retrodeck-sync ready. First run establishes the (empty) baseline — kick it with '~/.local/bin/retrodeck-sync.sh'."
{{ end -}}
